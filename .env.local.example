# ─── База данных ──────────────────────────────────────────────
# Из MongoDB Atlas: Connect → Drivers → копируй строку
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/trusttap

# ─── Telegram бот ─────────────────────────────────────────────
# Токен от @BotFather
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Канал для проверки подписки (с @ или числовой ID -100...)
CHANNEL_ID=@your_channel

# ─── Безопасность ─────────────────────────────────────────────
# Секретный ключ для /admin  (придумай сам, мин. 20 символов)
ADMIN_KEY=my_super_secret_admin_key_2025

# ─── Публичные переменные (видны в браузере) ──────────────────
# Имя бота без @ — для реферальных ссылок
NEXT_PUBLIC_BOT_USERNAME=YourBotUsername

# Ссылка на канал для задания «Подписаться»
NEXT_PUBLIC_CHANNEL_LINK=https://t.me/your_channel

# Ссылка для задания «Реклама»
NEXT_PUBLIC_AD_LINK=https://t.me/your_sponsor

# Ссылка на VIP канал
NEXT_PUBLIC_VIP_LINK=https://t.me/your_vip_channel
